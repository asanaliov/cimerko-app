@{
    Layout = "/Views/Shared/_Layout.cshtml";
}

<div class="account-manage-page">
    <header class="account-manage-header">
        <span class="account-manage-eyebrow">Account settings</span>
        <h1>Manage your account</h1>
        <p>Update your sign-in details, security settings, and personal data.</p>
    </header>

    <div class="account-manage-layout">
        <aside class="account-manage-sidebar">
            <partial name="_ManageNav"/>
        </aside>
        <section class="account-manage-content">
            @RenderBody()
        </section>
    </div>
</div>

@section Scripts {
    @await RenderSectionAsync("Scripts", required: false)
}
