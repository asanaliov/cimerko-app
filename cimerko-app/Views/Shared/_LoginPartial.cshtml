@using Microsoft.AspNetCore.Identity
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<ul class="navbar-nav site-account-nav">
    @if (SignInManager.IsSignedIn(User)) {
        var currentUser = await UserManager.GetUserAsync(User);
        var fullName = currentUser?.FullName.Trim();
        var firstName = string.IsNullOrWhiteSpace(fullName)
            ? "there"
            : fullName.Split(' ')[0];
        var initial = firstName[..1].ToUpperInvariant();
        var isLandlord = currentUser != null &&
                         await UserManager.IsInRoleAsync(currentUser, AppRoles.Landlord);
        var isAdmin = currentUser != null &&
                      await UserManager.IsInRoleAsync(currentUser, AppRoles.Admin);
        var accountLabel = isAdmin
            ? "Administrator"
            : isLandlord
                ? "Housing provider"
                : "Student member";

        @await Component.InvokeAsync("NotificationNav")
        <li class="nav-item dropdown">
            <button class="nav-link site-user-link dropdown-toggle"
                    type="button"
                    data-bs-toggle="dropdown"
                    aria-expanded="false">
                <span class="site-user-avatar" aria-hidden="true">
                    @if (!string.IsNullOrWhiteSpace(currentUser?.ProfileImageUrl)) {
                        <img src="@currentUser.ProfileImageUrl"
                             alt=""
                             onerror="this.hidden=true;this.nextElementSibling.classList.remove('d-none')"/>
                        <span class="site-user-initial d-none">@initial</span>
                    }
                    else {
                        <span class="site-user-initial">@initial</span>
                    }
                </span>
                <span>@firstName</span>
            </button>
            <ul class="dropdown-menu dropdown-menu-end site-user-menu">
                <li><span class="dropdown-header">@accountLabel</span></li>
                <li>
                    <a class="dropdown-item"
                       asp-area=""
                       asp-controller="Profile"
                       asp-action="MyProfile">My profile</a>
                </li>
                <li>
                    <a class="dropdown-item"
                       asp-area=""
                       asp-controller="SavedListing"
                       asp-action="Index">Saved listings</a>
                </li>
                <li>
                    <a class="dropdown-item"
                       asp-area=""
                       asp-controller="ListingRequest"
                       asp-action="Index">Requests</a>
                </li>
                @if (isLandlord || isAdmin) {
                    <li>
                        <a class="dropdown-item"
                           asp-area=""
                           asp-controller="Listing"
                           asp-action="Create">Post a listing</a>
                    </li>
                }
                <li>
                    <a class="dropdown-item"
                       asp-area="Identity"
                       asp-page="/Account/Manage/Index">Account settings</a>
                </li>
                <li><hr class="dropdown-divider"/></li>
                <li>
                    <form class="site-logout-form"
                          asp-area="Identity"
                          asp-page="/Account/Logout"
                          asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                        <button type="submit" class="dropdown-item">Log out</button>
                    </form>
                </li>
            </ul>
        </li>
    }
    else {
        <li class="nav-item">
            <a class="nav-link site-auth-link"
               asp-area="Identity"
               asp-page="/Account/Login">Login</a>
        </li>
        <li class="nav-item">
            <a class="nav-link site-auth-link site-auth-primary"
               asp-area="Identity"
               asp-page="/Account/Register">Create account</a>
        </li>
    }
</ul>
