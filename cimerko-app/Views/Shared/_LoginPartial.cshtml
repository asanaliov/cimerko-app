@using Microsoft.AspNetCore.Identity
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<ul class="navbar-nav site-account-nav">
    @if (SignInManager.IsSignedIn(User)) {
        var currentUser = await UserManager.GetUserAsync(User);
        var fullName = currentUser?.FullName.Trim();
        var firstName = string.IsNullOrWhiteSpace(fullName)
            ? "there"
            : fullName.Split(' ')[0];
        var initial = firstName[..1].ToUpperInvariant();

        @await Component.InvokeAsync("NotificationNav")
        <li class="nav-item">
            <a class="nav-link site-user-link"
               asp-area=""
               asp-controller="Profile"
               asp-action="MyProfile"
               title="View profile">
                <span class="site-user-avatar" aria-hidden="true">
                    @if (!string.IsNullOrWhiteSpace(currentUser?.ProfileImageUrl)) {
                        <img src="@currentUser.ProfileImageUrl"
                             alt=""
                             onerror="this.hidden=true;this.nextElementSibling.classList.remove('d-none')"/>
                        <span class="site-user-initial d-none">@initial</span>
                    }
                    else {
                        <span class="site-user-initial">@initial</span>
                    }
                </span>
                <span>@firstName</span>
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link site-settings-link"
               asp-area="Identity"
               asp-page="/Account/Manage/Index"
               aria-label="Manage account"
               title="Manage account">
                <svg viewBox="0 0 24 24" aria-hidden="true">
                    <circle cx="12" cy="12" r="3"/>
                    <path d="M19.4 15a1.7 1.7 0 0 0 .3 1.9l.1.1-2.8 2.8-.1-.1a1.7 1.7 0 0 0-1.9-.3 1.7 1.7 0 0 0-1 1.6v.2h-4V21a1.7 1.7 0 0 0-1-1.6 1.7 1.7 0 0 0-1.9.3l-.1.1L4.2 17l.1-.1a1.7 1.7 0 0 0 .3-1.9A1.7 1.7 0 0 0 3 14H2.8v-4H3a1.7 1.7 0 0 0 1.6-1 1.7 1.7 0 0 0-.3-1.9L4.2 7 7 4.2l.1.1a1.7 1.7 0 0 0 1.9.3A1.7 1.7 0 0 0 10 3v-.2h4V3a1.7 1.7 0 0 0 1 1.6 1.7 1.7 0 0 0 1.9-.3l.1-.1L19.8 7l-.1.1a1.7 1.7 0 0 0-.3 1.9 1.7 1.7 0 0 0 1.6 1h.2v4H21a1.7 1.7 0 0 0-1.6 1Z"/>
                </svg>
                <span class="visually-hidden">Manage account</span>
            </a>
        </li>
        <li class="nav-item">
            <form class="site-logout-form"
                  asp-area="Identity"
                  asp-page="/Account/Logout"
                  asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                <button type="submit" class="nav-link site-logout-button">Log out</button>
            </form>
        </li>
    }
    else {
        <li class="nav-item">
            <a class="nav-link site-auth-link"
               asp-area="Identity"
               asp-page="/Account/Register">Register</a>
        </li>
        <li class="nav-item">
            <a class="nav-link site-auth-link site-auth-primary"
               asp-area="Identity"
               asp-page="/Account/Login">Log in</a>
        </li>
    }
</ul>
