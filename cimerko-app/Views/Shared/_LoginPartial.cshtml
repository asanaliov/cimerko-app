@using Microsoft.AspNetCore.Identity
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<ul class="navbar-nav site-account-nav">
    @if (SignInManager.IsSignedIn(User)) {
        var currentUser = await UserManager.GetUserAsync(User);
        var fullName = currentUser?.FullName.Trim();
        var firstName = string.IsNullOrWhiteSpace(fullName)
            ? "there"
            : fullName.Split(' ')[0];
        var initial = firstName[..1].ToUpperInvariant();

        @await Component.InvokeAsync("NotificationNav")
        <li class="nav-item">
            <a class="nav-link site-user-link"
               asp-area=""
               asp-controller="Profile"
               asp-action="MyProfile"
               title="View profile">
                <span class="site-user-avatar" aria-hidden="true">
                    @if (!string.IsNullOrWhiteSpace(currentUser?.ProfileImageUrl)) {
                        <img src="@currentUser.ProfileImageUrl"
                             alt=""
                             onerror="this.hidden=true;this.nextElementSibling.classList.remove('d-none')"/>
                        <span class="site-user-initial d-none">@initial</span>
                    }
                    else {
                        <span class="site-user-initial">@initial</span>
                    }
                </span>
                <span>@firstName</span>
            </a>
        </li>
        <li class="nav-item">
            <form class="site-logout-form"
                  asp-area="Identity"
                  asp-page="/Account/Logout"
                  asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                <button type="submit" class="nav-link site-logout-button">Log out</button>
            </form>
        </li>
    }
    else {
        <li class="nav-item">
            <a class="nav-link site-auth-link"
               asp-area="Identity"
               asp-page="/Account/Register">Register</a>
        </li>
        <li class="nav-item">
            <a class="nav-link site-auth-link site-auth-primary"
               asp-area="Identity"
               asp-page="/Account/Login">Log in</a>
        </li>
    }
</ul>
