@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
    string NavLinkClass(string controller, string? action = null) =>
        string.Equals(currentController, controller, StringComparison.OrdinalIgnoreCase) &&
        (action == null || string.Equals(currentAction, action, StringComparison.OrdinalIgnoreCase))
            ? "nav-link site-nav-link is-active"
            : "nav-link site-nav-link";
}
<!DOCTYPE html>
<html lang="en-GB">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] - Cimerko</title>
    <link rel="icon" type="image/png" href="~/favicon-cimerko.png" asp-append-version="true"/>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/css/components.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/css/listings.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/css/profiles.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/css/activity.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/cimerko_app.styles.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/css/reference.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true"/>
</head>
<body>
@if (ViewData["HideGlobalHeader"] as bool? != true) {
<header class="site-header">
    <div class="container site-header-container">
        <nav class="navbar navbar-expand-lg site-navbar" aria-label="Main navigation">
            <div class="container-fluid px-0">
                <a class="navbar-brand site-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <span class="site-brand-mark" aria-hidden="true">
                        <svg viewBox="0 0 24 24">
                            <path d="M4 11.5 12 5l8 6.5V20H4z"/>
                            <path d="M9 20v-6h6v6"/>
                        </svg>
                    </span>
                    <span class="site-brand-copy">
                        <strong>Cimerko</strong>
                        <small>Good Living</small>
                    </span>
                </a>
                <button class="navbar-toggler site-navbar-toggler" type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#siteNavigation"
                        aria-controls="siteNavigation"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div id="siteNavigation" class="navbar-collapse collapse">
                    <ul class="navbar-nav site-nav-links me-auto">
                        <li class="nav-item">
                            <a class="@NavLinkClass("Home")"
                               aria-current="@(currentController == "Home" ? "page" : null)"
                               asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="@NavLinkClass("Listing")"
                               aria-current="@(currentController == "Listing" ? "page" : null)"
                               asp-area="" asp-controller="Listing" asp-action="Index">Listings</a>
                        </li>
                        <li class="nav-item">
                            <a class="@NavLinkClass("Profile", "Roommates")"
                               aria-current="@(currentController == "Profile" && currentAction == "Roommates" ? "page" : null)"
                               asp-area="" asp-controller="Profile" asp-action="Roommates">Roommates</a>
                        </li>
                        <li class="nav-item">
                            <a class="@NavLinkClass("Home", "Privacy")"
                               aria-current="@(currentController == "Home" && currentAction == "Privacy" ? "page" : null)"
                               asp-area="" asp-controller="Home" asp-action="Privacy">About</a>
                        </li>
                        @if (User.IsInRole(AppRoles.Admin)) {
                            <li class="nav-item">
                                <a class="@NavLinkClass("Admin")"
                                   aria-current="@(currentController == "Admin" ? "page" : null)"
                                   asp-area="" asp-controller="Admin" asp-action="Index">Admin panel</a>
                            </li>
                        }
                    </ul>
                    <partial name="_LoginPartial"/>
                </div>
            </div>
        </nav>
    </div>
</header>
}

@if (ViewData["NoContainer"] as bool? == true) {
    <main role="main" class="site-content pb-3">
        @RenderBody()
    </main>
} else {
    <div class="container site-content">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>
}

<footer class="site-footer">
    <div class="container">
        <div class="site-footer-content">
            <div>
                <a class="site-footer-brand" asp-controller="Home" asp-action="Index">Cimerko</a>
                <p>Student housing and roommate connections, kept simple.</p>
            </div>
            <nav aria-label="Footer navigation">
                <a asp-controller="Listing" asp-action="Index">Browse listings</a>
                <a asp-controller="Home" asp-action="Privacy">Privacy</a>
            </nav>
        </div>
        <p class="site-footer-copy">&copy; 2026 Cimerko. Built for student housing.</p>
    </div>
</footer>
<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
