@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    string NavLinkClass(string controller) =>
        string.Equals(currentController, controller, StringComparison.OrdinalIgnoreCase)
            ? "nav-link site-nav-link is-active"
            : "nav-link site-nav-link";
}
<!DOCTYPE html>
<html lang="en-GB">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] - Cimerko</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/cimerko_app.styles.css" asp-append-version="true"/>
</head>
<body>
<header class="site-header">
    <nav class="navbar navbar-expand-lg site-navbar" aria-label="Main navigation">
        <div class="container">
            <a class="navbar-brand site-brand" asp-area="" asp-controller="Home" asp-action="Index">
                <span class="site-brand-mark" aria-hidden="true">
                    <svg viewBox="0 0 24 24">
                        <path d="M4 11.5 12 5l8 6.5V20H4z"/>
                        <path d="M9 20v-6h6v6"/>
                    </svg>
                </span>
                <span>Cimerko</span>
            </a>
            <button class="navbar-toggler site-navbar-toggler" type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#siteNavigation"
                    aria-controls="siteNavigation"
                    aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div id="siteNavigation" class="navbar-collapse collapse">
                <ul class="navbar-nav site-nav-links me-auto">
                    <li class="nav-item">
                        <a class="@NavLinkClass("Home")"
                           aria-current="@(currentController == "Home" ? "page" : null)"
                           asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                    </li>
                    <li class="nav-item">
                        <a class="@NavLinkClass("Listing")"
                           aria-current="@(currentController == "Listing" ? "page" : null)"
                           asp-area="" asp-controller="Listing" asp-action="Index">Listings</a>
                    </li>
                    @if (User.Identity?.IsAuthenticated == true) {
                        <li class="nav-item">
                            <a class="@NavLinkClass("SavedListing")"
                               aria-current="@(currentController == "SavedListing" ? "page" : null)"
                               asp-area="" asp-controller="SavedListing" asp-action="Index">Saved listings</a>
                        </li>
                        <li class="nav-item">
                            <a class="@NavLinkClass("ListingRequest")"
                               aria-current="@(currentController == "ListingRequest" ? "page" : null)"
                               asp-area="" asp-controller="ListingRequest" asp-action="Index">Requests</a>
                        </li>
                    }
                </ul>
                <partial name="_LoginPartial"/>
            </div>
        </div>
    </nav>
</header>
<div class="container">
    <main role="main" class="pb-3">
        @RenderBody()
    </main>
</div>

<footer class="border-top footer text-muted">
    <div class="container">
        &copy; 2026 - Cimerko
    </div>
</footer>
<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
