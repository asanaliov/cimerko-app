@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<div class="error-page">
    <section class="error-card">
        <span class="error-card-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24">
                <path d="M12 8v5"/>
                <path d="M12 17h.01"/>
                <path d="M10.3 4.2 2.6 17.5A2 2 0 0 0 4.3 20h15.4a2 2 0 0 0 1.7-2.5L13.7 4.2a2 2 0 0 0-3.4 0Z"/>
            </svg>
        </span>
        <span class="error-card-eyebrow">Something went wrong</span>
        <h1>We could not load this page.</h1>
        <p>
            The problem may be temporary.
            Try again, or return to the listings to continue browsing.
        </p>

        <div class="error-card-actions">
            <a asp-controller="Home" asp-action="Index" class="btn-cimerko-light">Go home</a>
            <a asp-controller="Listing" asp-action="Index" class="btn-cimerko-primary">Browse listings</a>
        </div>

        @if (Model.ShowRequestId) {
            <details class="error-request-details">
                <summary>Technical details</summary>
                <p>
                    Request ID:
                    <code>@Model.RequestId</code>
                </p>
            </details>
        }
    </section>
</div>
