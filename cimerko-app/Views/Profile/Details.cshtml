@using System.Security.Claims
@model ApplicationUser

@{
    ViewData["Title"] = "Profile";
    var currentUserId = User.FindFirstValue(ClaimTypes.NameIdentifier);
    var profile = Model.RoommateProfile;
    var displayName = string.IsNullOrWhiteSpace(Model.FullName) ? Model.Email : Model.FullName;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>@displayName</h1>
    @if (currentUserId == Model.Id) {
        <a asp-action="Edit" class="btn btn-primary">Edit profile</a>
    }
</div>

@if (TempData["ReviewMessage"] != null) {
    <div class="alert alert-info">@TempData["ReviewMessage"]</div>
}

@if (!string.IsNullOrWhiteSpace(Model.ProfileImageUrl)) {
    <img src="@Model.ProfileImageUrl" alt="@displayName" class="img-thumbnail mb-3"
         style="width: 160px; height: 160px; object-fit: cover;"/>
}

@if (profile == null) {
    <div class="alert alert-info">This user has not completed a roommate profile.</div>
}
else {
    <dl class="row">
        <dt class="col-sm-3">Bio</dt>
        <dd class="col-sm-9">@(profile.Bio ?? "Not specified")</dd>

        <dt class="col-sm-3">Age</dt>
        <dd class="col-sm-9">@profile.Age</dd>

        <dt class="col-sm-3">City</dt>
        <dd class="col-sm-9">@profile.City</dd>

        <dt class="col-sm-3">Gender</dt>
        <dd class="col-sm-9">@(profile.Gender ?? "Not specified")</dd>

        <dt class="col-sm-3">University</dt>
        <dd class="col-sm-9">@(profile.University ?? "Not specified")</dd>

        <dt class="col-sm-3">Study program</dt>
        <dd class="col-sm-9">@(profile.StudyProgram ?? "Not specified")</dd>
    </dl>
}

<hr/>
<h2>Reviews</h2>

@if (!Model.ReviewsReceived.Any()) {
    <p class="text-muted">This user has no reviews.</p>
}
else {
    @foreach (var review in Model.ReviewsReceived.OrderByDescending(item => item.CreatedAt)) {
        var reviewerName = string.IsNullOrWhiteSpace(review.Reviewer?.FullName)
            ? review.Reviewer?.Email
            : review.Reviewer.FullName;

        <div class="card mb-3">
            <div class="card-body">
                <h5 class="card-title">@review.Rating / 5</h5>
                <h6 class="card-subtitle mb-2 text-muted">
                    @reviewerName · @review.CreatedAt.ToString("dd.MM.yyyy")
                </h6>
                @if (!string.IsNullOrWhiteSpace(review.Comment)) {
                    <p class="card-text">@review.Comment</p>
                }
                @if (currentUserId == review.ReviewerId) {
                    <form asp-controller="Review" asp-action="Delete" method="post">
                        <input type="hidden" name="id" value="@review.Id"/>
                        <button type="submit" class="btn btn-sm btn-outline-danger">Delete review</button>
                    </form>
                }
            </div>
        </div>
    }
}

@if (User.Identity?.IsAuthenticated == true && currentUserId != Model.Id) {
    <h3>Add review</h3>
    <form asp-controller="Review" asp-action="Create" method="post" class="col-md-6">
        <input type="hidden" name="reviewedUserId" value="@Model.Id"/>

        <div class="mb-3">
            <label for="rating" class="form-label">Rating</label>
            <select id="rating" name="rating" class="form-select">
                <option value="5">5</option>
                <option value="4">4</option>
                <option value="3">3</option>
                <option value="2">2</option>
                <option value="1">1</option>
            </select>
        </div>

        <div class="mb-3">
            <label for="comment" class="form-label">Comment</label>
            <textarea id="comment" name="comment" class="form-control" rows="4" maxlength="1000"></textarea>
        </div>

        <button type="submit" class="btn btn-primary">Add review</button>
    </form>
}
