@using System.Security.Claims
@model ApplicationUser

@{
    ViewData["Title"] = "Profile";
    var currentUserId = User.FindFirstValue(ClaimTypes.NameIdentifier);
    var profile = Model.RoommateProfile;
    var displayName = string.IsNullOrWhiteSpace(Model.FullName) ? Model.Email ?? "Cimerko member" : Model.FullName;
    var initial = displayName.Trim()[..1].ToUpperInvariant();
    var reviews = Model.ReviewsReceived.OrderByDescending(review => review.CreatedAt).ToList();
    var averageRating = reviews.Count == 0 ? 0 : reviews.Average(review => review.Rating);
    var canWriteReview = ViewBag.CanWriteReview == true;
    var showCompatibility = ViewBag.ShowCompatibility == true;
    var compatibilityScore = ViewBag.CompatibilityScore as int?;
    var comparedPreferences = ViewBag.ComparedPreferences is int preferenceCount ? preferenceCount : 0;
    var compatibilityStrongMatches =
        ViewBag.CompatibilityStrongMatches as IReadOnlyList<string> ?? Array.Empty<string>();
    var compatibilityPossibleConflicts =
        ViewBag.CompatibilityPossibleConflicts as IReadOnlyList<string> ?? Array.Empty<string>();
    var activeListings = Model.Listings
        .Where(listing => listing.IsActive)
        .OrderByDescending(listing => listing.CreatedAt)
        .ToList();
    var bioPreview = profile?.Bio;
    if (bioPreview?.Length > 180) {
        bioPreview = $"{bioPreview[..180].TrimEnd()}…";
    }

    var hasLivingPreferences =
        !string.IsNullOrWhiteSpace(profile?.SmokingPreference) ||
        !string.IsNullOrWhiteSpace(profile?.PetsPreference) ||
        !string.IsNullOrWhiteSpace(profile?.CleanlinessLevel) ||
        !string.IsNullOrWhiteSpace(profile?.SleepSchedule) ||
        !string.IsNullOrWhiteSpace(profile?.GuestPreference);
}

<div class="profile-details-shell">
    @if (TempData["ReviewMessage"] != null) {
        <div class="alert alert-info profile-details-alert" role="status">@TempData["ReviewMessage"]</div>
    }

    <section class="profile-hero">
        <div class="profile-hero-accent"></div>
        <div class="profile-hero-content">
            <div class="profile-hero-avatar" aria-label="@displayName profile picture">
                @if (!string.IsNullOrWhiteSpace(Model.ProfileImageUrl)) {
                    <img src="@Model.ProfileImageUrl" alt="@displayName"/>
                }
                else {
                    <span aria-hidden="true">@initial</span>
                }
            </div>

            <div class="profile-hero-identity">
                <span class="profile-kicker">Roommate profile</span>
                <h1>@displayName</h1>
                <div class="profile-hero-meta">
                    @if (!string.IsNullOrWhiteSpace(profile?.City)) {
                        <span>@profile.City</span>
                    }
                    @if (profile?.Age > 0) {
                        <span>@profile.Age years old</span>
                    }
                    <span>Member since @Model.CreatedAt.ToString("MMM yyyy")</span>
                </div>
                @if (!string.IsNullOrWhiteSpace(bioPreview)) {
                    <p class="profile-hero-bio">@bioPreview</p>
                }
            </div>

            @if (currentUserId == Model.Id) {
                <a asp-action="Edit" class="btn profile-edit-button">Edit profile</a>
            }
        </div>

        <div class="profile-hero-stats">
            <div>
                <strong>@(string.IsNullOrWhiteSpace(profile?.University) ? "—" : profile.University)</strong>
                <span>University</span>
            </div>
            <div>
                <strong>@(string.IsNullOrWhiteSpace(profile?.StudyProgram) ? "—" : profile.StudyProgram)</strong>
                <span>Study program</span>
            </div>
            <div>
                <strong>@(reviews.Count == 0 ? "New" : $"{averageRating:0.0} / 5")</strong>
                <span>@(reviews.Count == 1 ? "1 review" : $"{reviews.Count} reviews")</span>
            </div>
        </div>
    </section>

    <div class="profile-details-grid">
        <main class="profile-details-main">
            <section class="profile-content-card">
                <div class="profile-card-heading">
                    <span class="profile-kicker">Introduction</span>
                    <h2>About</h2>
                </div>

                @if (profile == null) {
                    <div class="profile-empty-state">
                        <h3>Profile details are not available yet</h3>
                        <p>This member has not completed their roommate profile.</p>
                    </div>
                }
                else {
                    <p class="profile-bio">
                        @(string.IsNullOrWhiteSpace(profile.Bio)
                            ? "This member has not added an introduction yet."
                            : profile.Bio)
                    </p>

                    <div class="profile-facts">
                        <div class="profile-fact">
                            <span>City</span>
                            <strong>@profile.City</strong>
                        </div>
                        <div class="profile-fact">
                            <span>Age</span>
                            <strong>@profile.Age</strong>
                        </div>
                        <div class="profile-fact">
                            <span>Gender</span>
                            <strong>@(profile.Gender ?? "Not specified")</strong>
                        </div>
                        <div class="profile-fact">
                            <span>University</span>
                            <strong>@(profile.University ?? "Not specified")</strong>
                        </div>
                        <div class="profile-fact profile-fact-wide">
                            <span>Study program</span>
                            <strong>@(profile.StudyProgram ?? "Not specified")</strong>
                        </div>
                    </div>
                }
            </section>

            <section class="profile-content-card">
                <div class="profile-card-heading">
                    <span class="profile-kicker">At home</span>
                    <h2>Living preferences</h2>
                </div>

                @if (profile == null || !hasLivingPreferences) {
                    <div class="profile-empty-state">
                        <h3>No living preferences yet</h3>
                        <p>This member has not shared their household preferences.</p>
                    </div>
                }
                else {
                    <div class="profile-preference-grid">
                        <div class="profile-preference-item">
                            <span>Smoking</span>
                            <strong>@(profile.SmokingPreference ?? "Not specified")</strong>
                        </div>
                        <div class="profile-preference-item">
                            <span>Pets</span>
                            <strong>@(profile.PetsPreference ?? "Not specified")</strong>
                        </div>
                        <div class="profile-preference-item">
                            <span>Cleanliness</span>
                            <strong>@(profile.CleanlinessLevel ?? "Not specified")</strong>
                        </div>
                        <div class="profile-preference-item">
                            <span>Sleep schedule</span>
                            <strong>@(profile.SleepSchedule ?? "Not specified")</strong>
                        </div>
                        <div class="profile-preference-item">
                            <span>Guests</span>
                            <strong>@(profile.GuestPreference ?? "Not specified")</strong>
                        </div>
                    </div>
                }
            </section>

            <section class="profile-listings-section">
                <div class="profile-section-title">
                    <div>
                        <span class="profile-kicker">Housing</span>
                        <h2>Active listings</h2>
                    </div>
                    @if (activeListings.Count > 0) {
                        <span class="profile-section-count">@activeListings.Count active</span>
                    }
                </div>

                @if (activeListings.Count == 0) {
                    <div class="profile-content-card profile-empty-state">
                        <h3>No active listings</h3>
                        <p>@displayName does not have any active housing listings right now.</p>
                    </div>
                }
                else {
                    <div class="profile-listing-grid">
                        @foreach (var listing in activeListings) {
                            var listingType = listing.Type switch {
                                ListingType.RoomOffer => "Room offer",
                                ListingType.RoommateWanted => "Roommate wanted",
                                ListingType.LookingForPlace => "Looking for a place",
                                _ => listing.Type.ToString()
                            };

                            <article class="profile-listing-card">
                                <div>
                                    <span class="profile-listing-type">@listingType</span>
                                    <h3>@listing.Title</h3>
                                    <p>@listing.City · @listing.RoomCount @(listing.RoomCount == 1 ? "room" : "rooms")</p>
                                </div>
                                <div class="profile-listing-footer">
                                    <strong>@listing.MonthlyRent.ToString("0") € <small>/ month</small></strong>
                                    <a asp-controller="Listing" asp-action="Details" asp-route-id="@listing.Id">
                                        View listing
                                    </a>
                                </div>
                            </article>
                        }
                    </div>
                }
            </section>

            <section class="profile-reviews-section">
                <div class="profile-section-title">
                    <div>
                        <span class="profile-kicker">Community feedback</span>
                        <h2>Reviews</h2>
                    </div>
                    @if (reviews.Count > 0) {
                        <span class="profile-section-count">@averageRating.ToString("0.0") / 5</span>
                    }
                </div>

                @if (reviews.Count == 0) {
                    <div class="profile-content-card profile-empty-state">
                        <h3>No reviews yet</h3>
                        <p>Reviews from other Cimerko members will appear here.</p>
                    </div>
                }
                else {
                    <div class="profile-review-list">
                        @foreach (var review in reviews) {
                            var reviewerName = string.IsNullOrWhiteSpace(review.Reviewer?.FullName)
                                ? review.Reviewer?.Email ?? "Cimerko member"
                                : review.Reviewer.FullName;
                            var reviewerInitial = reviewerName.Trim()[..1].ToUpperInvariant();
                            var hasDetailedRatings =
                                review.SmokingRating.HasValue ||
                                review.PetsRating.HasValue ||
                                review.CleanlinessRating.HasValue ||
                                review.SleepScheduleRating.HasValue ||
                                review.GuestPreferenceRating.HasValue;

                            <article class="profile-review-card">
                                <header class="profile-review-header">
                                    <a asp-controller="Profile" asp-action="Details" asp-route-id="@review.ReviewerId"
                                       class="profile-reviewer">
                                        <span class="profile-reviewer-avatar">
                                            @if (!string.IsNullOrWhiteSpace(review.Reviewer?.ProfileImageUrl)) {
                                                <img src="@review.Reviewer.ProfileImageUrl" alt=""/>
                                            }
                                            else {
                                                <span aria-hidden="true">@reviewerInitial</span>
                                            }
                                        </span>
                                        <span>
                                            <strong>@reviewerName</strong>
                                            <small>@review.CreatedAt.ToString("dd MMM yyyy")</small>
                                        </span>
                                    </a>
                                    <div class="profile-review-stars" aria-label="@review.Rating out of 5 stars">
                                        @for (var star = 1; star <= 5; star++) {
                                            <span class="@(star <= review.Rating ? "is-filled" : "")">★</span>
                                        }
                                    </div>
                                </header>

                                @if (!string.IsNullOrWhiteSpace(review.Comment)) {
                                    <p>@review.Comment</p>
                                }

                                @if (hasDetailedRatings) {
                                    <div class="profile-review-breakdown">
                                        @if (review.SmokingRating.HasValue) {
                                            <div><span>Smoking</span><strong>@review.SmokingRating / 5</strong></div>
                                        }
                                        @if (review.PetsRating.HasValue) {
                                            <div><span>Pets</span><strong>@review.PetsRating / 5</strong></div>
                                        }
                                        @if (review.CleanlinessRating.HasValue) {
                                            <div><span>Cleanliness</span><strong>@review.CleanlinessRating / 5</strong></div>
                                        }
                                        @if (review.SleepScheduleRating.HasValue) {
                                            <div><span>Sleep schedule</span><strong>@review.SleepScheduleRating / 5</strong></div>
                                        }
                                        @if (review.GuestPreferenceRating.HasValue) {
                                            <div><span>Guests</span><strong>@review.GuestPreferenceRating / 5</strong></div>
                                        }
                                    </div>
                                }

                                @if (currentUserId == review.ReviewerId) {
                                    <form asp-controller="Review" asp-action="Delete" method="post"
                                          class="profile-review-delete">
                                        <input type="hidden" name="id" value="@review.Id"/>
                                        <button type="submit" class="btn btn-link text-danger">Delete review</button>
                                    </form>
                                }
                            </article>
                        }
                    </div>
                }
            </section>
        </main>

        <aside class="profile-details-sidebar">
            @if (showCompatibility) {
                <section class="profile-compatibility-card">
                    <span class="profile-kicker">Your compatibility</span>
                    @if (compatibilityScore.HasValue) {
                        <div class="profile-compatibility-score">@compatibilityScore%</div>
                        <p>
                            Based on @comparedPreferences shared
                            @(comparedPreferences == 1 ? "preference" : "preferences").
                        </p>
                        <div class="profile-compatibility-breakdown">
                            @if (compatibilityStrongMatches.Count > 0) {
                                <div>
                                    <h3>Strong matches</h3>
                                    <ul class="profile-match-list">
                                        @foreach (var match in compatibilityStrongMatches) {
                                            <li>@match</li>
                                        }
                                    </ul>
                                </div>
                            }
                            @if (compatibilityPossibleConflicts.Count > 0) {
                                <div>
                                    <h3>Possible conflicts</h3>
                                    <ul class="profile-conflict-list">
                                        @foreach (var conflict in compatibilityPossibleConflicts) {
                                            <li>@conflict</li>
                                        }
                                    </ul>
                                </div>
                            }
                        </div>
                    }
                    else {
                        <div class="profile-compatibility-score">—</div>
                        <p>Not enough information to calculate compatibility.</p>
                    }
                    <small>Smoking and cleanliness have the greatest influence.</small>
                </section>
            }

            <section class="profile-review-summary-card">
                <span class="profile-kicker">Reviews</span>
                <div class="profile-review-score">
                    <strong>@(reviews.Count == 0 ? "—" : averageRating.ToString("0.0"))</strong>
                    <span>out of 5</span>
                </div>
                <div class="profile-review-summary-stars" aria-label="Average rating">
                    @for (var star = 1; star <= 5; star++) {
                        <span class="@(star <= Math.Round(averageRating) ? "is-filled" : "")">★</span>
                    }
                </div>
                <p>
                    @(reviews.Count == 0
                        ? "No community reviews have been added yet."
                        : $"Based on {reviews.Count} {(reviews.Count == 1 ? "review" : "reviews")}.")
                </p>
                <div class="profile-review-policy">
                    Reviews are limited to people connected through an accepted housing request.
                </div>
            </section>

            @if (canWriteReview) {
                <section class="profile-review-form-card">
                    <div class="profile-card-heading">
                        <span class="profile-kicker">Share feedback</span>
                        <h2>Write a review</h2>
                    </div>

                    <form asp-controller="Review" asp-action="Create" method="post">
                        <input type="hidden" name="reviewedUserId" value="@Model.Id"/>

                        <div class="mb-3">
                            <label for="rating" class="form-label">Overall rating</label>
                            <select id="rating" name="rating" class="form-select">
                                <option value="5">5 — Excellent</option>
                                <option value="4">4 — Very good</option>
                                <option value="3">3 — Good</option>
                                <option value="2">2 — Fair</option>
                                <option value="1">1 — Poor</option>
                            </select>
                        </div>

                        <div class="profile-review-details-heading">
                            <strong>Living compatibility</strong>
                            <span>Rate each area from 1 to 5.</span>
                        </div>

                        <div class="mb-3">
                            <label for="smokingRating" class="form-label">Smoking habits</label>
                            <select id="smokingRating" name="smokingRating" class="form-select" required>
                                <option value="">Choose a rating</option>
                                <option value="5">5 — Excellent</option>
                                <option value="4">4 — Very good</option>
                                <option value="3">3 — Good</option>
                                <option value="2">2 — Fair</option>
                                <option value="1">1 — Poor</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label for="petsRating" class="form-label">Pet responsibility</label>
                            <select id="petsRating" name="petsRating" class="form-select" required>
                                <option value="">Choose a rating</option>
                                <option value="5">5 — Excellent</option>
                                <option value="4">4 — Very good</option>
                                <option value="3">3 — Good</option>
                                <option value="2">2 — Fair</option>
                                <option value="1">1 — Poor</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label for="cleanlinessRating" class="form-label">Cleanliness</label>
                            <select id="cleanlinessRating" name="cleanlinessRating" class="form-select" required>
                                <option value="">Choose a rating</option>
                                <option value="5">5 — Excellent</option>
                                <option value="4">4 — Very good</option>
                                <option value="3">3 — Good</option>
                                <option value="2">2 — Fair</option>
                                <option value="1">1 — Poor</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label for="sleepScheduleRating" class="form-label">Sleep schedule</label>
                            <select id="sleepScheduleRating" name="sleepScheduleRating" class="form-select" required>
                                <option value="">Choose a rating</option>
                                <option value="5">5 — Excellent</option>
                                <option value="4">4 — Very good</option>
                                <option value="3">3 — Good</option>
                                <option value="2">2 — Fair</option>
                                <option value="1">1 — Poor</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label for="guestPreferenceRating" class="form-label">Guest habits</label>
                            <select id="guestPreferenceRating" name="guestPreferenceRating" class="form-select" required>
                                <option value="">Choose a rating</option>
                                <option value="5">5 — Excellent</option>
                                <option value="4">4 — Very good</option>
                                <option value="3">3 — Good</option>
                                <option value="2">2 — Fair</option>
                                <option value="1">1 — Poor</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label for="comment" class="form-label">Comment</label>
                            <textarea id="comment" name="comment" class="form-control" rows="4" maxlength="1000"
                                      placeholder="Share your experience with this member."></textarea>
                        </div>

                        <button type="submit" class="btn btn-primary w-100">Publish review</button>
                    </form>
                </section>
            }
        </aside>
    </div>
</div>
