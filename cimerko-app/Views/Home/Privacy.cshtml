@{
    ViewData["Title"] = "Privacy Policy";
}

<div class="privacy-page">
    <header>
        <span class="listing-eyebrow">Your information</span>
        <h1>Privacy policy</h1>
        <p>
            This page explains what information Cimerko stores and how it is used to provide housing,
            roommate matching, messaging, and account features.
        </p>
    </header>

    <section>
        <h2>Information you provide</h2>
        <p>
            Cimerko stores account details, profile information, listing content, uploaded images,
            housing requests, reviews, reports, and notifications that you submit through the application.
        </p>
    </section>

    <section>
        <h2>How information is used</h2>
        <p>
            Your information is used to operate your account, publish approved listings, calculate roommate
            compatibility, connect users, moderate content, and keep the service secure.
        </p>
    </section>

    <section>
        <h2>Public information</h2>
        <p>
            Approved listings and the profile details you choose to complete may be visible to other users.
            Do not publish sensitive information that you do not want others to see.
        </p>
    </section>

    <section>
        <h2>Cookies and sign-in</h2>
        <p>
            The application uses essential authentication and security cookies to keep you signed in,
            protect forms, and remember your account session.
        </p>
    </section>

    <section>
        <h2>Data access and removal</h2>
        <p>
            You can update your profile and listings from your account.
            Contact an administrator if you need help accessing, correcting, or removing account data.
        </p>
    </section>

    <section>
        <h2>Safety</h2>
        <p>
            Cimerko applies account controls and moderation, but no online service can guarantee absolute
            security.
            Use the reporting tools if you see suspicious content or activity.
        </p>
    </section>
</div>
