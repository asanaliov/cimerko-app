@using cimerko_app.Models.Enums
@model cimerko_app.Models.ViewModels.HomeIndexViewModel

@{
    ViewData["Title"] = "Student housing and roommates";

    var featuredListing = Model.LatestListings
        .FirstOrDefault(listing => listing.Images.Count > 0)
        ?? Model.LatestListings.FirstOrDefault();
    var featuredImages = featuredListing?.Images
        .OrderByDescending(image => image.IsPrimary)
        .ThenBy(image => image.CreatedAt)
        .ToList()
        ?? [];
    var featuredImage = featuredImages.FirstOrDefault();
    var featuredLocation = featuredListing == null
        ? string.Empty
        : string.IsNullOrWhiteSpace(featuredListing.Address)
            ? featuredListing.City
            : $"{featuredListing.Address}, {featuredListing.City}";
    var featuredMapQuery = Uri.EscapeDataString(featuredLocation);
    var featuredPhotoGallery = new cimerko_app.Models.ViewModels.ListingPhotoGalleryViewModel {
        DialogId = "homePhotoViewer",
        Title = featuredListing?.Title ?? string.Empty,
        Images = featuredImages
    };
}

<div class="home-page home-marketplace">
    @if (featuredListing != null) {
        <section class="home-showcase" aria-labelledby="featuredListingTitle">
            <div class="home-showcase-media">
                @if (featuredImage != null) {
                    <img src="@featuredImage.ImageUrl"
                         alt="@featuredListing.Title"
                         class="home-showcase-image"/>
                }
                else {
                    <div class="home-showcase-placeholder">
                        <svg viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M3 10 12 3l9 7v10H3z"/>
                            <path d="M9 20v-6h6v6"/>
                        </svg>
                        <span>Photos coming soon</span>
                    </div>
                }

                @if (featuredImages.Count > 0) {
                    <div class="home-showcase-thumbnails" aria-label="Featured listing photos">
                        @for (var photoIndex = 0;
                              photoIndex < Math.Min(featuredImages.Count, 4);
                              photoIndex++) {
                            var image = featuredImages[photoIndex];
                            <button type="button"
                                    data-gallery-open="homePhotoViewer"
                                    data-gallery-index="@photoIndex"
                                    aria-label="View photo @(photoIndex + 1) of @featuredListing.Title">
                                <img src="@image.ImageUrl" alt=""/>
                            </button>
                        }
                    </div>
                }

                <div class="home-showcase-actions">
                    @if (featuredImage != null) {
                        <button type="button"
                                class="home-showcase-pill"
                                data-gallery-open="homePhotoViewer"
                                data-gallery-index="0">
                            <svg viewBox="0 0 24 24" aria-hidden="true">
                                <rect x="3" y="5" width="18" height="16" rx="2"/>
                                <circle cx="9" cy="10" r="2"/>
                                <path d="m21 16-5-5L5 21"/>
                            </svg>
                            View @featuredImages.Count @(featuredImages.Count == 1 ? "photo" : "photos")
                        </button>
                    }
                    <a asp-controller="Listing"
                       asp-action="Details"
                       asp-route-id="@featuredListing.Id"
                       class="home-showcase-pill">
                        <svg viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M4 12h16M14 6l6 6-6 6"/>
                        </svg>
                        View listing
                    </a>
                    <a href="https://www.openstreetmap.org/search?query=@featuredMapQuery"
                       target="_blank"
                       rel="noopener"
                       class="home-showcase-pill">
                        <svg viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M20 10c0 5.5-8 11-8 11S4 15.5 4 10a8 8 0 1 1 16 0Z"/>
                            <circle cx="12" cy="10" r="2.5"/>
                        </svg>
                        Map view
                    </a>
                </div>
            </div>

            <aside class="home-featured-card">
                <div class="home-featured-strip">
                    <span>
                        <svg viewBox="0 0 24 24" aria-hidden="true">
                            <path d="m12 3 2.8 5.7 6.2.9-4.5 4.4 1.1 6.2-5.6-3-5.6 3 1.1-6.2L3 9.6l6.2-.9z"/>
                        </svg>
                        Featured listing
                    </span>
                    <span>Active</span>
                </div>

                <div class="home-featured-body">
                    <span class="home-featured-type">@featuredListing.Type.GetDisplayName()</span>
                    <h1 id="featuredListingTitle">@featuredListing.Title</h1>
                    <p class="home-featured-city">@featuredListing.City</p>

                    <div class="home-featured-price">
                        <span>Monthly rent</span>
                        <div>
                            <strong>@featuredListing.MonthlyRent.ToString("0") €</strong>
                            <small>/ month</small>
                        </div>
                        <a asp-controller="Listing"
                           asp-action="Details"
                           asp-route-id="@featuredListing.Id">
                            View details and availability
                        </a>
                    </div>

                    <div class="home-featured-facts">
                        <span>@featuredListing.RoomCount @(featuredListing.RoomCount == 1 ? "room" : "rooms")</span>
                        <span>@(featuredListing.AvailableFrom?.ToString("dd MMM") ?? "Available now")</span>
                        @if (featuredListing.Type == ListingType.LookingForRoommate &&
                             featuredListing.RoommatesNeeded.HasValue) {
                            <span>@featuredListing.RoommatesNeeded roommate needed</span>
                        }
                    </div>

                    <p class="home-featured-location">
                        <svg viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M20 10c0 5.5-8 11-8 11S4 15.5 4 10a8 8 0 1 1 16 0Z"/>
                            <circle cx="12" cy="10" r="2.5"/>
                        </svg>
                        @featuredLocation
                    </p>
                </div>
            </aside>
        </section>

        @if (featuredImage != null) {
            <partial name="_ListingPhotoGallery"
                     model="featuredPhotoGallery"/>
        }
    }
    else {
        <section class="home-showcase-empty">
            <span class="home-eyebrow">Student housing made simpler</span>
            <h1>Find a room. Find a cimer. Feel at home.</h1>
            <p>New student homes and roommate listings will appear here as soon as they are published.</p>
            <a asp-controller="Listing" asp-action="Create" class="btn home-primary-action">Post a listing</a>
        </section>
    }

    <nav class="home-category-tabs" aria-label="Browse housing categories">
        <a asp-controller="Listing" asp-action="Index" class="is-active">
            <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="m12 3 2.8 5.7 6.2.9-4.5 4.4 1.1 6.2-5.6-3-5.6 3 1.1-6.2L3 9.6l6.2-.9z"/>
            </svg>
            Recommended
        </a>
        <a asp-controller="Listing"
           asp-action="Index"
           asp-route-Type="@ListingType.PlaceForRent">
            <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M3 10 12 3l9 7v10H3z"/>
                <path d="M9 20v-6h6v6"/>
            </svg>
            Places for rent
        </a>
        <a asp-controller="Profile" asp-action="Roommates">
            <svg viewBox="0 0 24 24" aria-hidden="true">
                <circle cx="9" cy="8" r="3"/>
                <circle cx="17" cy="10" r="2"/>
                <path d="M3 19c.4-4 2.4-6 6-6s5.6 2 6 6M15 15c3 0 4.7 1.3 5 4"/>
            </svg>
            Roommates
        </a>
        <a asp-controller="Listing"
           asp-action="Index"
           asp-route-AvailableNow="true">
            <svg viewBox="0 0 24 24" aria-hidden="true">
                <rect x="3" y="5" width="18" height="16" rx="2"/>
                <path d="M8 3v4M16 3v4M3 10h18"/>
            </svg>
            Available now
        </a>
    </nav>

    <section class="home-latest" aria-labelledby="latestListingsTitle">
        <div class="home-section-heading home-section-heading-row">
            <div>
                <h2 id="latestListingsTitle">Top places for students</h2>
                <p>Recently added homes and roommate opportunities.</p>
            </div>
            <a asp-controller="Listing" asp-action="Index">
                View all listings
                <span aria-hidden="true">→</span>
            </a>
        </div>

        @if (Model.LatestListings.Count == 0) {
            <div class="home-latest-empty">
                <h3>No active listings yet</h3>
                <p>Be the first person to share a place or look for a roommate.</p>
                <a asp-controller="Listing" asp-action="Create" class="btn home-primary-action">Post a listing</a>
            </div>
        }
        else {
            <div class="home-listing-grid">
                @foreach (var listing in Model.LatestListings) {
                    var primaryImage = listing.Images
                        .OrderByDescending(image => image.IsPrimary)
                        .ThenBy(image => image.CreatedAt)
                        .FirstOrDefault();

                    <article class="home-listing-card">
                        <a asp-controller="Listing"
                           asp-action="Details"
                           asp-route-id="@listing.Id"
                           class="home-listing-image"
                           aria-label="View @listing.Title">
                            @if (primaryImage != null) {
                                <img src="@primaryImage.ImageUrl"
                                     alt="@listing.Title"
                                     loading="lazy"/>
                            }
                            else {
                                <span class="home-listing-placeholder">
                                    <svg viewBox="0 0 24 24" aria-hidden="true">
                                        <path d="M3 10 12 3l9 7v10H3z"/>
                                        <path d="M9 20v-6h6v6"/>
                                    </svg>
                                    No photo
                                </span>
                            }
                        </a>

                        <div class="home-listing-body">
                            <div class="home-listing-heading">
                                <h3>
                                    <a asp-controller="Listing"
                                       asp-action="Details"
                                       asp-route-id="@listing.Id">@listing.Title</a>
                                </h3>
                                <div class="home-listing-price">
                                    <strong>@listing.MonthlyRent.ToString("0") €</strong>
                                    <span>/ month</span>
                                </div>
                            </div>
                            <p class="home-listing-location">
                                <svg viewBox="0 0 24 24" aria-hidden="true">
                                    <path d="M20 10c0 5.5-8 11-8 11S4 15.5 4 10a8 8 0 1 1 16 0Z"/>
                                    <circle cx="12" cy="10" r="2.5"/>
                                </svg>
                                @listing.City
                            </p>
                            <div class="home-listing-facts">
                                <span>@listing.Type.GetDisplayName()</span>
                                <span>@listing.RoomCount @(listing.RoomCount == 1 ? "room" : "rooms")</span>
                                <span>@(listing.AvailableFrom?.ToString("dd MMM") ?? "Available now")</span>
                            </div>
                        </div>
                    </article>
                }
            </div>
        }
    </section>

    <section class="home-how" aria-labelledby="homeHowTitle">
        <div class="home-section-heading">
            <span class="home-eyebrow">How it works</span>
            <h2 id="homeHowTitle">From profile to new home</h2>
        </div>
        <ol class="home-steps">
            <li><span>1</span><strong>Create your profile</strong><p>Share the details and routines that matter at home.</p></li>
            <li><span>2</span><strong>Browse listings</strong><p>Filter active places and roommate posts.</p></li>
            <li><span>3</span><strong>Send a request</strong><p>Introduce yourself directly to the listing owner.</p></li>
            <li><span>4</span><strong>Connect</strong><p>Track the response and choose the right fit.</p></li>
        </ol>
    </section>

    <section class="home-final-cta">
        <div>
            <span class="home-eyebrow">Ready to start?</span>
            <h2>Your next home could be one search away.</h2>
        </div>
        <div>
            <a asp-controller="Listing" asp-action="Index" class="btn home-primary-action">Browse listings</a>
            <a asp-controller="Listing" asp-action="Create" class="btn home-secondary-action">Post listing</a>
        </div>
    </section>
</div>
