@model cimerko_app.Models.ViewModels.AdminDashboardViewModel
@{
    ViewData["Title"] = "Admin dashboard";
}

<section class="admin-dashboard">
    <header class="admin-dashboard-header">
        <div>
            <span class="admin-dashboard-eyebrow">Administration</span>
            <h1>Dashboard overview</h1>
            <p>Review platform activity and handle items that need attention.</p>
        </div>
    </header>

    <partial name="_AdminNavigation"/>

    <div class="admin-stats" aria-label="Platform summary">
        <article class="admin-stat-card">
            <span>Total users</span>
            <strong>@Model.UserCount</strong>
            <small>@Model.NewUsersThisWeek new this week</small>
        </article>
        <article class="admin-stat-card">
            <span>Total listings</span>
            <strong>@Model.ListingCount</strong>
        </article>
        <article class="admin-stat-card">
            <span>Pending approval</span>
            <strong>@Model.PendingListingCount</strong>
            <small>Listings awaiting review</small>
        </article>
        <article class="admin-stat-card">
            <span>Open reports</span>
            <strong>@Model.OpenReportCount</strong>
            <small>@Model.NewUsersThisMonth new users this month</small>
        </article>
    </div>

    @if (TempData["AdminMessage"] != null) {
        <div class="alert alert-info">@TempData["AdminMessage"]</div>
    }

    <div class="admin-dashboard-grid">
        <section class="admin-panel-card" aria-labelledby="pending-listings-heading">
            <div class="admin-panel-heading">
                <div>
                    <span>Listings</span>
                    <h2 id="pending-listings-heading">Pending approval</h2>
                </div>
                <a asp-action="Listings" asp-route-status="@ListingModerationStatus.Pending">View all</a>
            </div>

            @if (Model.RecentPendingListings.Count == 0) {
                <p class="admin-empty-state">No listings are waiting for approval.</p>
            }
            else {
                <div class="table-responsive">
                    <table class="table admin-table">
                        <thead>
                        <tr>
                            <th scope="col">Listing</th>
                            <th scope="col">Owner</th>
                            <th scope="col">Submitted</th>
                            <th scope="col"><span class="visually-hidden">Actions</span></th>
                        </tr>
                        </thead>
                        <tbody>
                        @foreach (var listing in Model.RecentPendingListings) {
                            <tr>
                                <td>@listing.Title</td>
                                <td>@(listing.Owner?.FullName ?? listing.Owner?.Email)</td>
                                <td>@listing.CreatedAt.ToLocalTime().ToString("dd MMM yyyy")</td>
                                <td>
                                    <a asp-controller="Listing"
                                       asp-action="Details"
                                       asp-route-id="@listing.Id">Review</a>
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            }
        </section>

        <section class="admin-panel-card" aria-labelledby="open-reports-heading">
            <div class="admin-panel-heading">
                <div>
                    <span>Moderation</span>
                    <h2 id="open-reports-heading">Recent reports</h2>
                </div>
                <a asp-action="Reports">View all</a>
            </div>

            @if (Model.RecentOpenReports.Count == 0) {
                <p class="admin-empty-state">There are no open reports.</p>
            }
            else {
                <div class="table-responsive">
                    <table class="table admin-table">
                        <thead>
                        <tr>
                            <th scope="col">Target</th>
                            <th scope="col">Reason</th>
                            <th scope="col">Reported</th>
                        </tr>
                        </thead>
                        <tbody>
                        @foreach (var report in Model.RecentOpenReports) {
                            <tr>
                                <td>
                                    @(report.TargetType == ReportTargetType.Listing
                                        ? report.Listing?.Title
                                        : report.ReportedUser?.FullName)
                                </td>
                                <td>@report.Reason.GetDisplayName()</td>
                                <td>@report.CreatedAt.ToLocalTime().ToString("dd MMM yyyy")</td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            }
        </section>
    </div>
</section>
