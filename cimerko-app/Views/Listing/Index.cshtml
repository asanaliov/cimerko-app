@model cimerko_app.Models.ViewModels.ListingIndexViewModel

@{
    ViewData["Title"] = "Listings";
    var currentUserId = ViewBag.CurrentUserId as string;
    var returnUrl = $"{Context.Request.Path}{Context.Request.QueryString}";
    var saveUrl = Url.Action("Save", "SavedListing");
    var removeUrl = Url.Action("Remove", "SavedListing");
}

<div class="page-shell">
    <section class="listing-discovery">
        <div class="listing-discovery-main">
            <header class="listing-page-header">
                <div>
                    <h1 class="listing-page-title">Find your perfect place in Skopje</h1>
                    <p class="listing-page-intro">Quality student housing, verified and tailored for you.</p>
                </div>

                @if (User.Identity?.IsAuthenticated == true) {
                    <a asp-action="Create" class="btn-cimerko-primary listing-create-button">
                        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 5v14M5 12h14"/></svg>
                        Create listing
                    </a>
                }
            </header>

    <form asp-action="Index" method="get" class="listing-discovery-form">
        <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3" role="alert"></div>

        <div class="listing-search-custom flex-column flex-md-row align-items-stretch align-items-md-center gap-3">
            <div class="search-input-group py-2">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--cimerko-muted)" stroke-width="2.5" class="flex-shrink-0" aria-hidden="true"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
                <input asp-for="Title" placeholder="Search listings" />
            </div>

            <div class="search-divider d-none d-md-block"></div>

            <div class="search-input-group py-2">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--cimerko-muted)" stroke-width="2.5" class="flex-shrink-0" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
                <input asp-for="City" placeholder="Skopje, North Macedonia" />
            </div>

            <button type="submit" class="btn-search-purple py-3 px-4 justify-content-center">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="me-1" aria-hidden="true"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
                Search
            </button>
        </div>

        <details class="mb-5" open="@(Model.HasAdvancedFilters ? "open" : null)">
            <summary class="filters-toggle-summary">
                <span>
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="me-2"><line x1="4" y1="21" x2="4" y2="14"></line><line x1="4" y1="10" x2="4" y2="3"></line><line x1="12" y1="21" x2="12" y2="12"></line><line x1="12" y1="8" x2="12" y2="3"></line><line x1="20" y1="21" x2="20" y2="16"></line><line x1="20" y1="12" x2="20" y2="3"></line><line x1="1" y1="14" x2="7" y2="14"></line><line x1="9" y1="8" x2="15" y2="8"></line><line x1="17" y1="16" x2="23" y2="16"></line></svg>
                    More filters
                </span>
                <div class="d-flex align-items-center gap-2">
                    @if (Model.HasAdvancedFilters) {
                        <span class="badge-soft">filters applied</span>
                    }
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"></polyline></svg>
                </div>
            </summary>

            <div class="filters-grid-custom">
                <div class="row g-3">
                    <div class="col-6 col-md-3">
                        <label asp-for="Type">Listing type</label>
                        <select asp-for="Type" asp-items="Html.GetEnumSelectList<ListingType>()">
                            <option value="">Any type</option>
                        </select>
                    </div>
                    <div class="col-6 col-md-3">
                        <label asp-for="MinimumBudget">Minimum budget</label>
                        <input asp-for="MinimumBudget" type="number" min="0" step="0.01" placeholder="No minimum"/>
                    </div>
                    <div class="col-6 col-md-3">
                        <label asp-for="MaximumBudget">Maximum budget</label>
                        <input asp-for="MaximumBudget" type="number" min="0" step="0.01" placeholder="No maximum"/>
                        <span asp-validation-for="MaximumBudget" class="listing-form-error"></span>
                    </div>
                    <div class="col-6 col-md-3">
                        <label asp-for="CleanlinessLevel">Cleanliness</label>
                        <select asp-for="CleanlinessLevel">
                            <option value="">Any level</option>
                            <option value="Relaxed">Relaxed</option>
                            <option value="Balanced">Balanced</option>
                            <option value="Very tidy">Very tidy</option>
                        </select>
                    </div>
                    <div class="col-6 col-md-3">
                        <label asp-for="SmokingPreference">Smoking</label>
                        <select asp-for="SmokingPreference">
                            <option value="">Any preference</option>
                            <option value="No smoking">No smoking</option>
                            <option value="Outside only">Outside only</option>
                            <option value="Smoking is okay">Smoking is okay</option>
                        </select>
                    </div>
                    <div class="col-6 col-md-3">
                        <label asp-for="PetsPreference">Pets</label>
                        <select asp-for="PetsPreference">
                            <option value="">Any preference</option>
                            <option value="No pets">No pets</option>
                            <option value="Pets are welcome">Pets are welcome</option>
                            <option value="Ask first">Ask first</option>
                        </select>
                    </div>
                    <div class="col-6 col-md-3">
                        <label asp-for="SleepSchedule">Sleep schedule</label>
                        <select asp-for="SleepSchedule">
                            <option value="">Any schedule</option>
                            <option value="Early bird">Early bird</option>
                            <option value="Flexible">Flexible</option>
                            <option value="Night owl">Night owl</option>
                        </select>
                    </div>
                    <div class="col-6 col-md-3">
                        <label asp-for="GuestPreference">Guests</label>
                        <select asp-for="GuestPreference">
                            <option value="">Any preference</option>
                            <option value="Rarely">Rarely</option>
                            <option value="Occasionally">Occasionally</option>
                            <option value="Often">Often</option>
                        </select>
                    </div>
                </div>

                <div class="d-flex flex-column flex-md-row align-items-start align-items-md-center justify-content-between pt-4 border-top mt-4 gap-3">
                    <div class="d-flex align-items-center gap-3">
                        <label class="form-check d-flex align-items-center gap-2 m-0 p-0">
                            <input asp-for="AvailableNow" class="form-check-input m-0"/>
                            <span class="filter-check-label">Available now</span>
                        </label>
                        <label class="form-check d-flex align-items-center gap-2 m-0 p-0">
                            <input asp-for="HasImages" class="form-check-input m-0"/>
                            <span class="filter-check-label">Has images</span>
                        </label>
                    </div>
                    <div>
                        @if (Model.HasActiveFilters) {
                            <a asp-action="Index" class="filter-clear-link">Clear all</a>
                        }
                        <button type="submit" class="btn-cimerko-primary filter-apply-button">Apply filters</button>
                    </div>
                </div>
            </div>
        </details>
    </form>
            <nav class="listing-category-tabs" aria-label="Listing categories">
                <a asp-action="Index" class="is-active">Recommended</a>
                <a asp-action="Index" asp-route-Type="@ListingType.PlaceForRent">Private rooms</a>
                <a asp-action="Index" asp-route-Type="@ListingType.LookingForRoommate">Shared rooms</a>
                <a asp-action="Index" asp-route-AvailableNow="true">Studios</a>
            </nav>
        </div>

        <aside class="listing-map-card" aria-label="Map of listings in Skopje">
            <span class="listing-map-label">Skopje</span>
            <span class="listing-map-pin pin-one">⌂</span>
            <span class="listing-map-pin pin-two">⌂</span>
            <span class="listing-map-pin pin-three">⌂</span>
            <span class="listing-map-pin pin-four">⌂</span>
            <span class="listing-map-pin pin-five">⌂</span>
            <span class="listing-map-controls" aria-hidden="true">+<i></i>−</span>
            <button type="button" class="listing-map-search">Search this area</button>
        </aside>
    </section>

    <div class="listing-results-heading mb-4">
        <div>
            <h2>Available listings</h2>
            <p>
                @if (Model.Listings.Count == 1) {
                    <span>1 listing found</span>
                }
                else {
                    <span>@Model.Listings.Count listings found</span>
                }
                @if (Model.HasActiveFilters) {
                    <span> for your search criteria</span>
                }
            </p>
        </div>
    </div>

    @if (Model.Listings.Count == 0) {
        <div class="empty-state py-5">
            <svg class="empty-state-icon" viewBox="0 0 24 24" aria-hidden="true"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
            <h3>@(Model.HasActiveFilters ? "No matches this time" : "No listings yet")</h3>
            <p class="text-muted mt-2 mb-4">
                @(Model.HasActiveFilters
                    ? "Try broadening your search or removing a few filters."
                    : "New places for rent and roommate requests will appear here as soon as they are posted.")
            </p>
            @if (Model.HasActiveFilters) {
                <a asp-action="Index" class="btn-cimerko-primary filter-apply-button">Clear filters</a>
            }
        </div>
    }
    else {
        <div class="row g-4 listing-card-grid">
            @foreach (var listing in Model.Listings) {
                var typeLabel = listing.Type.GetDisplayName();
                var ownerName = string.IsNullOrWhiteSpace(listing.Owner?.FullName)
                    ? listing.Owner?.Email ?? "Cimerko member"
                    : listing.Owner.FullName;
                var ownerInitial = ownerName.Trim()[..1].ToUpperInvariant();
                var primaryImage = listing.Images
                    .OrderByDescending(image => image.IsPrimary)
                    .ThenBy(image => image.CreatedAt)
                    .FirstOrDefault();
                var canSave = currentUserId != null && currentUserId != listing.OwnerId;
                var isSaved = Model.SavedListingIds.Contains(listing.Id);

                <div class="col-12 col-md-6 col-xl-4">
                    <article class="listing-card">
                        <div class="listing-card-img-wrap">
                            <span class="listing-card-featured">☆ Featured</span>
                            @if (canSave) {
                                <form asp-controller="SavedListing"
                                      asp-action="@(isSaved ? "Remove" : "Save")"
                                      method="post"
                                      class="listing-card-save-form"
                                      data-save-url="@saveUrl"
                                      data-remove-url="@removeUrl"
                                      data-listing-title="@listing.Title">
                                    <input type="hidden" name="listingId" value="@listing.Id"/>
                                    <input type="hidden" name="returnUrl" value="@returnUrl"/>
                                    <button type="submit"
                                            class="listing-card-save-btn @(isSaved ? "is-saved" : "")"
                                            aria-label="@(isSaved ? $"Remove {listing.Title} from saved listings" : $"Save {listing.Title}")"
                                            title="@(isSaved ? "Remove from saved listings" : "Save listing")">
                                        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M20.8 4.6a5.5 5.5 0 0 0-7.8 0L12 5.7l-1.1-1.1a5.5 5.5 0 0 0-7.8 7.8l1.1 1.1L12 21.2l7.8-7.8 1.1-1.1a5.5 5.5 0 0 0-.1-7.7z"></path></svg>
                                    </button>
                                </form>
                            }
                            <a asp-action="Details"
                               asp-route-id="@listing.Id"
                               class="listing-card-image-link"
                               aria-label="View @listing.Title">
                                @if (primaryImage != null) {
                                    <img src="@primaryImage.ImageUrl"
                                         alt="@listing.Title"
                                         class="listing-card-img"
                                         loading="lazy"/>
                                } else {
                                    <span class="listing-card-placeholder">
                                        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path></svg>
                                        <span>No photo</span>
                                    </span>
                                }
                            </a>
                        </div>
                        <div class="listing-card-content">
                            <div>
                                <h3><a asp-action="Details" asp-route-id="@listing.Id">@listing.Title</a></h3>
                                <div class="listing-card-location-new">
                                    <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
                                    <span>@listing.City</span>
                                </div>
                                <div class="listing-card-reference-price">
                                    <strong>@listing.MonthlyRent.ToString("0") €</strong>
                                    <span>/ month</span>
                                    <span class="listing-card-rating">★ 4.6 <small>(132)</small></span>
                                </div>
                                @if (!string.IsNullOrWhiteSpace(listing.Description)) {
                                    <p class="listing-card-description">
                                        @listing.Description
                                    </p>
                                }
                                <div class="listing-card-badges">
                                    <span class="badge-soft">@typeLabel</span>
                                    <span class="badge-soft">@listing.RoomCount @(listing.RoomCount == 1 ? "room" : "rooms")</span>
                                    @if (listing.Type == ListingType.LookingForRoommate && listing.RoommatesNeeded.HasValue) {
                                        <span class="badge-soft">@listing.RoommatesNeeded needed</span>
                                    }
                                    <span class="badge-soft">@(listing.AvailableFrom?.ToString("dd MMM") ?? "Available now")</span>
                                </div>
                            </div>
                            <div class="listing-card-footer-new">
                                <div class="listing-card-owner">
                                    <div class="avatar-circle avatar-circle-sm">
                                        @if (!string.IsNullOrWhiteSpace(listing.Owner?.ProfileImageUrl)) {
                                            <img src="@listing.Owner.ProfileImageUrl" alt=""/>
                                        } else {
                                            <span>@ownerInitial</span>
                                        }
                                    </div>
                                    <span>By <strong>@ownerName</strong></span>
                                </div>
                                <a asp-action="Details"
                                   asp-route-id="@listing.Id"
                                   class="cimerko-primary-button listing-card-details-link">
                                    View details
                                    <svg viewBox="0 0 24 24" aria-hidden="true">
                                        <path d="m9 18 6-6-6-6"/>
                                    </svg>
                                </a>
                            </div>
                        </div>
                    </article>
                </div>
            }
        </div>
    }
</div>

@section Scripts {
    <script>
        (() => {
            document.querySelectorAll(".listing-card-save-form").forEach(form => {
                form.addEventListener("submit", async event => {
                    event.preventDefault();

                    const button = form.querySelector(".listing-card-save-btn");
                    const listingTitle = form.dataset.listingTitle;
                    button.disabled = true;

                    try {
                        const response = await fetch(form.action, {
                            method: "POST",
                            body: new FormData(form),
                            headers: {
                                "Accept": "application/json",
                                "X-Requested-With": "XMLHttpRequest"
                            }
                        });

                        if (!response.ok) {
                            throw new Error(`Save request failed with status ${response.status}.`);
                        }

                        const result = await response.json();
                        const isSaved = result.isSaved === true;
                        const actionLabel = isSaved
                            ? `Remove ${listingTitle} from saved listings`
                            : `Save ${listingTitle}`;

                        form.action = isSaved ? form.dataset.removeUrl : form.dataset.saveUrl;
                        button.classList.toggle("is-saved", isSaved);
                        button.title = isSaved ? "Remove from saved listings" : "Save listing";
                        button.setAttribute("aria-label", actionLabel);
                    }
                    catch (error) {
                        console.error(error);
                    }
                    finally {
                        button.disabled = false;
                    }
                });
            });
        })();
    </script>
}
