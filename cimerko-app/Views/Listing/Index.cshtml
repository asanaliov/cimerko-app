@model IEnumerable<Listing>

@{
    ViewData["Title"] = "Listings";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Listings</h1>
    @if (User.Identity?.IsAuthenticated == true) {
        <a asp-action="Create" class="btn btn-primary">Create listing</a>
    }
</div>

<form asp-action="Index" method="get" class="row g-2 mb-4">
    <div class="col-md-5">
        <input name="title" value="@ViewBag.TitleFilter" class="form-control" placeholder="Search by title"/>
    </div>
    <div class="col-md-5">
        <input name="city" value="@ViewBag.CityFilter" class="form-control" placeholder="Search by city"/>
    </div>
    <div class="col-md-2">
        <button type="submit" class="btn btn-outline-primary w-100">Search</button>
    </div>
</form>

@if (!Model.Any()) {
    <div class="alert alert-info">No active listings were found.</div>
}
else {
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        @foreach (var listing in Model) {
            <div class="col">
                <div class="card h-100">
                    <div class="card-body">
                        <h5 class="card-title">@listing.Title</h5>
                        <p class="card-text mb-1"><strong>Type:</strong> @listing.Type</p>
                        <p class="card-text mb-1"><strong>City:</strong> @listing.City</p>
                        <p class="card-text mb-1"><strong>Rent:</strong> @listing.MonthlyRent.ToString("0.00") €</p>
                        <p class="card-text text-muted">
                            Posted by
                            <a asp-controller="Profile" asp-action="Details" asp-route-id="@listing.OwnerId">
                                @(string.IsNullOrWhiteSpace(listing.Owner?.FullName)
                                    ? listing.Owner?.Email
                                    : listing.Owner.FullName)
                            </a>
                        </p>
                    </div>
                    <div class="card-footer bg-white">
                        <a asp-action="Details" asp-route-id="@listing.Id" class="btn btn-outline-primary">Details</a>
                    </div>
                </div>
            </div>
        }
    </div>
}
