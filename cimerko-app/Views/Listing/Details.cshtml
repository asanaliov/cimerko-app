@using System.Security.Claims
@model Listing

@{
    ViewData["Title"] = "Listing details";
    var currentUserId = User.FindFirstValue(ClaimTypes.NameIdentifier);
}

<h1>@Model.Title</h1>

@if (TempData["RequestMessage"] != null) {
    <div class="alert alert-info">@TempData["RequestMessage"]</div>
}

<dl class="row">
    <dt class="col-sm-3">Type</dt>
    <dd class="col-sm-9">@Model.Type</dd>

    <dt class="col-sm-3">Description</dt>
    <dd class="col-sm-9">@Model.Description</dd>

    <dt class="col-sm-3">City</dt>
    <dd class="col-sm-9">@Model.City</dd>

    <dt class="col-sm-3">Address</dt>
    <dd class="col-sm-9">@(Model.Address ?? "Not specified")</dd>

    <dt class="col-sm-3">Monthly rent</dt>
    <dd class="col-sm-9">@Model.MonthlyRent.ToString("0.00") €</dd>

    <dt class="col-sm-3">Rooms</dt>
    <dd class="col-sm-9">@Model.RoomCount</dd>

    <dt class="col-sm-3">Available from</dt>
    <dd class="col-sm-9">@(Model.AvailableFrom?.ToString("dd.MM.yyyy") ?? "Immediately")</dd>

    <dt class="col-sm-3">Owner</dt>
    <dd class="col-sm-9">@(Model.Owner?.FullName ?? Model.Owner?.Email)</dd>
</dl>

<div>
    @if (currentUserId == Model.OwnerId) {
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Edit</a>
        <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger">Delete</a>
    }
    else if (User.Identity?.IsAuthenticated == true) {
        @if (ViewBag.IsSaved == true) {
            <form asp-controller="SavedListing" asp-action="Remove" method="post" class="d-inline">
                <input type="hidden" name="listingId" value="@Model.Id"/>
                <input type="hidden" name="returnTo" value="details"/>
                <button type="submit" class="btn btn-outline-danger">Remove from saved</button>
            </form>
        }
        else {
            <form asp-controller="SavedListing" asp-action="Save" method="post" class="d-inline">
                <input type="hidden" name="listingId" value="@Model.Id"/>
                <button type="submit" class="btn btn-outline-primary">Save listing</button>
            </form>
        }
    }
    <a asp-action="Index" class="btn btn-outline-secondary">Back to listings</a>
</div>

@if (User.Identity?.IsAuthenticated == true && currentUserId != Model.OwnerId) {
    var existingRequest = ViewBag.ExistingRequest as ListingRequest;

    <hr/>
    <h2>Listing request</h2>

    @if (existingRequest != null) {
        <p>
            You sent a request on @existingRequest.CreatedAt.ToString("dd.MM.yyyy").
            Current status: <strong>@existingRequest.Status</strong>.
        </p>
    }
    else {
        <form asp-controller="ListingRequest" asp-action="Create" method="post" class="col-md-6">
            <input type="hidden" name="listingId" value="@Model.Id"/>
            <div class="mb-3">
                <label for="message" class="form-label">Message</label>
                <textarea id="message" name="message" class="form-control" rows="4" maxlength="1000"
                          required></textarea>
            </div>
            <button type="submit" class="btn btn-primary">Send request</button>
        </form>
    }
}
