@model cimerko_app.Models.ViewModels.ListingDetailsViewModel

@{
    ViewData["Title"] = Model.Listing.Title;
    var listing = Model.Listing;
    var owner = listing.Owner;
    var ownerProfile = owner?.RoommateProfile;
    var ownerName = string.IsNullOrWhiteSpace(owner?.FullName)
        ? "Cimerko member"
        : owner.FullName;
    var ownerInitial = ownerName.Trim()[..1].ToUpperInvariant();
    var listingImages = listing.Images
        .OrderByDescending(image => image.IsPrimary)
        .ThenBy(image => image.CreatedAt)
        .ToList();
    var primaryImage = listingImages.FirstOrDefault();
    var typeLabel = listing.Type.GetDisplayName();
    var availableLabel = listing.AvailableFrom.HasValue
        ? listing.AvailableFrom.Value.ToString("dd MMM yyyy")
        : "Available now";
    var hasExactLocation = !string.IsNullOrWhiteSpace(listing.Address);
    var requestStatusClass = Model.ExistingRequest?.Status switch {
        RequestStatus.Accepted => "text-success",
        RequestStatus.Rejected => "text-danger",
        _ => "text-warning"
    };
}

<div class="cimerko-page">
    <div class="mb-4">
        <a asp-action="Index" class="text-decoration-none text-muted fw-bold">
            &larr; Back to listings
        </a>
    </div>

    @if (TempData["RequestMessage"] != null) {
        <div class="alert alert-success rounded-3 mb-4">
            @TempData["RequestMessage"]
        </div>
    }

    <div class="hero-layout">
        <!-- Thumbnails (Desktop) -->
        <div class="hero-thumbnails">
            @foreach (var img in listingImages.Take(4)) {
                <img src="@img.ImageUrl" class="hero-thumb" alt="Thumbnail" />
            }
        </div>

        <!-- Main Content Column -->
        <div>
            <!-- Hero Image -->
            <div class="hero-main-img-container mb-4">
                @if (primaryImage != null) {
                    <img src="@primaryImage.ImageUrl" class="hero-main-img" alt="Listing image" />
                    <div class="hero-img-overlay"></div>
                } else {
                    <div class="w-100 h-100 bg-light d-flex align-items-center justify-content-center text-muted">
                        No photos added yet
                    </div>
                }
                
                <div class="hero-img-actions">
                    @if(listingImages.Count > 0) {
                        <button class="hero-action-btn">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><circle cx="8.5" cy="8.5" r="1.5"></circle><polyline points="21 15 16 10 5 21"></polyline></svg>
                            View Photos
                        </button>
                    }
                    <button class="hero-action-btn">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"></path><polyline points="16 6 12 2 8 6"></polyline><line x1="12" y1="2" x2="12" y2="15"></line></svg>
                        Share
                    </button>
                </div>
            </div>

            <!-- Tabs -->
            <nav class="details-tabs">
                <a href="#overview" class="nav-link active">Overview</a>
                <a href="#details" class="nav-link">Details</a>
                <a href="#landlord" class="nav-link">Landlord</a>
                <a href="#reviews" class="nav-link">Reviews</a>
            </nav>

            <!-- Sections -->
            <section id="overview" class="details-section">
                <h3>Overview</h3>
                <p class="mb-4 text-muted" style="line-height: 1.7; font-size: 1.05rem;">
                    @(string.IsNullOrWhiteSpace(listing.Description) ? "No description provided." : listing.Description)
                </p>

                <div class="fact-grid">
                    <div class="fact-item">
                        <small>Monthly rent</small>
                        <strong>@listing.MonthlyRent.ToString("0") €</strong>
                    </div>
                    <div class="fact-item">
                        <small>Location</small>
                        <strong>@listing.City</strong>
                    </div>
                    <div class="fact-item">
                        <small>Available from</small>
                        <strong>@availableLabel</strong>
                    </div>
                    <div class="fact-item">
                        <small>Listing type</small>
                        <strong>@typeLabel</strong>
                    </div>
                    <div class="fact-item">
                        <small>Rooms</small>
                        <strong>@listing.RoomCount</strong>
                    </div>
                    @if (listing.Type == ListingType.LookingForRoommate && listing.RoommatesNeeded.HasValue) {
                        <div class="fact-item">
                            <small>Roommates needed</small>
                            <strong>@listing.RoommatesNeeded</strong>
                        </div>
                    }
                </div>
            </section>

            <section id="details" class="details-section">
                <h3>Preferences</h3>
                @if (ownerProfile != null && (
                    !string.IsNullOrWhiteSpace(ownerProfile.SmokingPreference) ||
                    !string.IsNullOrWhiteSpace(ownerProfile.PetsPreference) ||
                    !string.IsNullOrWhiteSpace(ownerProfile.CleanlinessLevel) ||
                    !string.IsNullOrWhiteSpace(ownerProfile.SleepSchedule) ||
                    !string.IsNullOrWhiteSpace(ownerProfile.GuestPreference))) {
                    <div class="d-flex flex-wrap gap-2">
                        @if (!string.IsNullOrWhiteSpace(ownerProfile.SmokingPreference)) { <span class="cimerko-badge">@ownerProfile.SmokingPreference</span> }
                        @if (!string.IsNullOrWhiteSpace(ownerProfile.PetsPreference)) { <span class="cimerko-badge">@ownerProfile.PetsPreference</span> }
                        @if (!string.IsNullOrWhiteSpace(ownerProfile.CleanlinessLevel)) { <span class="cimerko-badge">@ownerProfile.CleanlinessLevel</span> }
                        @if (!string.IsNullOrWhiteSpace(ownerProfile.SleepSchedule)) { <span class="cimerko-badge">@ownerProfile.SleepSchedule</span> }
                        @if (!string.IsNullOrWhiteSpace(ownerProfile.GuestPreference)) { <span class="cimerko-badge">@ownerProfile.GuestPreference</span> }
                    </div>
                } else {
                    <p class="text-muted">No preferences have been shared yet.</p>
                }
            </section>

            <section id="landlord" class="details-section">
                <h3>Meet the Landlord</h3>
                <div class="landlord-mini border-top-0 pt-0 mt-0">
                    <div class="landlord-mini-avatar">
                        @if (!string.IsNullOrWhiteSpace(owner?.ProfileImageUrl)) {
                            <img src="@owner.ProfileImageUrl" alt="Avatar"/>
                        } else {
                            @ownerInitial
                        }
                    </div>
                    <div class="landlord-mini-info">
                        <h4>@ownerName</h4>
                        <p>@owner?.Email</p>
                    </div>
                    <div class="ms-auto">
                        <a asp-controller="Profile" asp-action="Details" asp-route-id="@listing.OwnerId" class="btn btn-light rounded-pill fw-bold text-dark px-4 shadow-sm">View Profile</a>
                    </div>
                </div>
            </section>
            
            <section id="reviews" class="details-section">
                <h3>Reviews</h3>
                @if (Model.OwnerReviewCount > 0) {
                    <div class="d-flex align-items-center gap-2 mb-4">
                        <span class="fs-4 fw-bold">@(Model.OwnerAverageRating.HasValue ? Model.OwnerAverageRating.Value.ToString("0.0") : "—")</span>
                        <div class="text-warning fs-5">★</div>
                        <span class="text-muted ms-2">(@Model.OwnerReviewCount reviews)</span>
                    </div>
                } else {
                    <div class="text-center py-4 text-muted">
                        No reviews yet.
                    </div>
                }
            </section>
        </div>

        <!-- Floating Action Card -->
        <aside>
            <div class="floating-card">
                @if (listing.Type == ListingType.LookingForRoommate) {
                    <div class="floating-card-banner">Student Listing</div>
                } else {
                    <div class="floating-card-banner">Place for Rent</div>
                }
                
                <h2 class="floating-card-title">@listing.Title</h2>
                <div class="floating-card-location">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
                    @(hasExactLocation ? listing.Address + ", " : "")@listing.City
                </div>
                
                <div class="floating-card-price">
                    @listing.MonthlyRent.ToString("0")€ <span>/ month</span>
                </div>
                
                <div class="floating-card-badges">
                    @if(listing.AvailableFrom == null || listing.AvailableFrom <= DateTime.Now) {
                        <span class="cimerko-badge">Available now</span>
                    }
                    @if(Model.OwnerReviewCount >= 3 && Model.OwnerAverageRating >= 4.5) {
                        <span class="cimerko-badge">Popular</span>
                    }
                    @if(listing.MonthlyRent < 400) {
                        <span class="cimerko-badge">Budget friendly</span>
                    }
                </div>

                @if (Model.IsOwner) {
                    <a asp-action="Edit" asp-route-id="@listing.Id" class="btn-primary-action">Edit listing</a>
                    <a asp-action="Delete" asp-route-id="@listing.Id" class="btn-secondary-action text-danger">Delete listing</a>
                } else if (!listing.IsActive) {
                    <div class="alert alert-secondary text-center rounded-3 fw-bold">Inactive Listing</div>
                } else if (User.Identity?.IsAuthenticated == true) {
                    @if (Model.ExistingRequest != null) {
                        <div class="alert alert-info rounded-3 text-center fw-bold">
                            Request @Model.ExistingRequest.Status
                        </div>
                        <a asp-controller="ListingRequest" asp-action="Index" class="btn-secondary-action">View Requests</a>
                    } else {
                        <form asp-controller="ListingRequest" asp-action="Create" method="post" class="mb-2">
                            <input type="hidden" name="listingId" value="@listing.Id"/>
                            <textarea name="message" class="form-control rounded-3 mb-2 bg-light border-0" rows="3" placeholder="Hi! I am interested..." required></textarea>
                            <button type="submit" class="btn-primary-action">Request / Contact</button>
                        </form>
                    }
                    
                    @if (Model.IsSaved) {
                        <form asp-controller="SavedListing" asp-action="Remove" method="post">
                            <input type="hidden" name="listingId" value="@listing.Id"/>
                            <input type="hidden" name="returnTo" value="details"/>
                            <button type="submit" class="btn-secondary-action">Remove from saved</button>
                        </form>
                    } else {
                        <form asp-controller="SavedListing" asp-action="Save" method="post">
                            <input type="hidden" name="listingId" value="@listing.Id"/>
                            <button type="submit" class="btn-secondary-action">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
                                Save
                            </button>
                        </form>
                    }
                } else {
                    <a asp-area="Identity" asp-page="/Account/Login" asp-route-returnUrl="@Url.Action("Details", "Listing", new { id = listing.Id })" class="btn-primary-action">Sign in to contact</a>
                }

                <div class="landlord-mini">
                    <div class="landlord-mini-avatar">
                        @if (!string.IsNullOrWhiteSpace(owner?.ProfileImageUrl)) {
                            <img src="@owner.ProfileImageUrl" alt="Avatar"/>
                        } else {
                            @ownerInitial
                        }
                    </div>
                    <div class="landlord-mini-info">
                        <h4>@ownerName</h4>
                        <p>@owner?.Email</p>
                    </div>
                </div>
            </div>
        </aside>
    </div>
</div>
