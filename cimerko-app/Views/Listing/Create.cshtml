@model Listing

@{
    var isRoommateForm = Model.Type == ListingType.LookingForRoommate;
    ViewData["Title"] = isRoommateForm ? "Post a roommate listing" : "Create listing";
}

<div class="listing-form-page">
    <header class="listing-form-header">
        <div>
            <span class="listing-form-eyebrow">@(isRoommateForm ? "Roommate search" : "New listing")</span>
            <h1>@(isRoommateForm ? "Find the right roommate." : "List your place.")</h1>
            <p>
                @(isRoommateForm
                    ? "Share your housing plan and the lifestyle preferences that matter to you."
                    : "Add the essentials now. You can update every detail later.")
            </p>
        </div>

        <a asp-action="Index" class="listing-form-back">
            <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="m15 18-6-6 6-6"/>
            </svg>
            Back to listings
        </a>
    </header>

    <form asp-action="Create"
          class="listing-form-layout"
          enctype="multipart/form-data"
          data-listing-type-form>
        <div class="listing-form-card detail-card">
            <div asp-validation-summary="ModelOnly" class="listing-form-validation" role="alert"></div>

            <section class="listing-form-section">
                <div class="listing-form-section-heading">
                    <span>01</span>
                    <div>
                        <h2>Listing basics</h2>
                        <p>Give people a clear first impression.</p>
                    </div>
                </div>

                <div class="listing-form-fields">
                    <div class="listing-form-field listing-form-field-wide">
                        <label asp-for="Title"></label>
                        <input asp-for="Title"
                               placeholder="e.g. Bright room near the city centre"
                               autocomplete="off"/>
                        <span asp-validation-for="Title" class="listing-form-error"></span>
                    </div>

                    <div class="listing-form-field listing-form-field-wide">
                        <label asp-for="Type">What are you posting?</label>
                        <select asp-for="Type"
                                asp-items="Html.GetEnumSelectList<ListingType>()"
                                aria-describedby="listingTypeHelp"
                                data-listing-type
                                required>
                            <option value="">Choose a listing type</option>
                        </select>
                        <small id="listingTypeHelp"
                               class="listing-form-field-hint listing-type-help"
                               data-listing-type-help
                               aria-live="polite">
                            Choose whether you are listing a place for rent or looking for a roommate.
                        </small>
                        <span asp-validation-for="Type" class="listing-form-error"></span>
                    </div>

                    <div class="listing-form-field listing-form-field-wide">
                        <div class="listing-form-label-row">
                            <label asp-for="Description"></label>
                            <span>Be specific and welcoming</span>
                        </div>
                        <textarea asp-for="Description"
                                  rows="6"
                                  placeholder="Describe the space, the household, and what kind of roommate would be a good fit..."></textarea>
                        <span asp-validation-for="Description" class="listing-form-error"></span>
                    </div>
                </div>
            </section>

            <section class="listing-form-section">
                <div class="listing-form-section-heading">
                    <span>02</span>
                    <div>
                        <h2>Location</h2>
                        <p>Help people understand where the place is.</p>
                    </div>
                </div>

                <div class="listing-form-fields">
                    <div class="listing-form-field">
                        <label asp-for="City"></label>
                        <input asp-for="City" placeholder="e.g. Berlin" autocomplete="address-level2"/>
                        <span asp-validation-for="City" class="listing-form-error"></span>
                    </div>

                    <div class="listing-form-field">
                        <div class="listing-form-label-row">
                            <label asp-for="Address"></label>
                            <span>Optional</span>
                        </div>
                        <input asp-for="Address" placeholder="Street or neighbourhood" autocomplete="street-address"/>
                        <span asp-validation-for="Address" class="listing-form-error"></span>
                    </div>

                    <div class="listing-form-field listing-form-field-wide">
                        <label asp-for="ContactPhone"></label>
                        <input asp-for="ContactPhone"
                               type="tel"
                               autocomplete="tel"
                               placeholder="+389 70 123 456"/>
                        <small class="listing-form-field-hint">
                            This number appears on the listing so interested users can contact you.
                        </small>
                        <span asp-validation-for="ContactPhone" class="listing-form-error"></span>
                    </div>
                </div>
            </section>

            <section class="listing-form-section">
                <div class="listing-form-section-heading">
                    <span>03</span>
                    <div>
                        <h2>Price and availability</h2>
                        <p>Set expectations before people get in touch.</p>
                    </div>
                </div>

                <div class="listing-form-fields listing-form-fields-four" data-listing-facts-fields>
                    <div class="listing-form-field">
                        <label asp-for="MonthlyRent">Monthly rent</label>
                        <div class="listing-form-input-suffix">
                            <input asp-for="MonthlyRent"
                                   type="number"
                                   min="0"
                                   max="100000"
                                   step="0.01"
                                   placeholder="650"/>
                            <span>€</span>
                        </div>
                        <span asp-validation-for="MonthlyRent" class="listing-form-error"></span>
                    </div>

                    <div class="listing-form-field">
                        <label asp-for="RoomCount">Rooms</label>
                        <input asp-for="RoomCount" type="number" min="1" max="20" placeholder="1"/>
                        <span asp-validation-for="RoomCount" class="listing-form-error"></span>
                    </div>

                    <div class="listing-form-field"
                         data-bedrooms-field
                         hidden="@(Model.Type != ListingType.PlaceForRent &&
                                   Model.Type != ListingType.LookingForRoommate)">
                        <label asp-for="BedroomCount"></label>
                        <label class="listing-studio-toggle">
                            <input type="checkbox"
                                   name="isStudio"
                                   value="true"
                                   checked="@(Model.BedroomCount == 0)"
                                   data-studio-toggle/>
                            <span>This is a studio</span>
                        </label>
                        <input asp-for="BedroomCount"
                               type="number"
                               min="0"
                               max="20"
                               placeholder="1"
                               data-bedrooms/>
                        <small class="listing-form-field-hint">Enter the number of separate bedrooms.</small>
                        <span asp-validation-for="BedroomCount" class="listing-form-error"></span>
                    </div>

                    <div class="listing-form-field"
                         data-roommates-needed-field
                         hidden="@(Model.Type != ListingType.LookingForRoommate)">
                        <label asp-for="RoommatesNeeded"></label>
                        <input asp-for="RoommatesNeeded"
                               type="number"
                               min="1"
                               max="10"
                               placeholder="1"
                               data-roommates-needed/>
                        <small class="listing-form-field-hint">How many roommates do you need?</small>
                        <span asp-validation-for="RoommatesNeeded" class="listing-form-error"></span>
                    </div>

                    <div class="listing-form-field">
                        <div class="listing-form-label-row">
                            <label asp-for="AvailableFrom">Available from</label>
                            <span>Optional</span>
                        </div>
                        <input asp-for="AvailableFrom" type="date"/>
                        <span asp-validation-for="AvailableFrom" class="listing-form-error"></span>
                    </div>
                </div>
            </section>

            <partial name="_ListingPreferencesFields" model="Model"/>

            <section class="listing-form-section">
                <div class="listing-form-section-heading">
                    <span>05</span>
                    <div>
                        <h2>Photos</h2>
                        <p>Show the space clearly with a few useful photos.</p>
                    </div>
                </div>

                <div class="listing-image-upload">
                    <label for="listingImages">
                        <span class="listing-image-upload-icon">
                            <svg viewBox="0 0 24 24" aria-hidden="true">
                                <rect x="3" y="5" width="18" height="16" rx="2"/>
                                <circle cx="9" cy="10" r="2"/>
                                <path d="m21 16-5-5L5 21M14 13l-2-2-3 3"/>
                            </svg>
                        </span>
                        <span>
                            <strong id="listingImagesLabel">Choose listing images</strong>
                            <small>Upload up to 5 JPG, PNG, or WebP images.</small>
                        </span>
                    </label>
                    <input id="listingImages"
                           name="listingImages"
                           type="file"
                           accept="image/jpeg,image/png,image/webp"
                           multiple/>
                </div>
                <div id="listingImageSelection"
                     class="listing-image-selection"
                     aria-live="polite"
                     hidden>
                    <p id="listingImageCount"></p>
                    <div id="listingImagePreviews" class="listing-image-preview-grid"></div>
                </div>
                @Html.ValidationMessage(
                    "listingImages",
                    null,
                    new { @class = "listing-form-error listing-image-upload-error" })
            </section>

            <div class="listing-form-actions">
                <a asp-action="Index"
                   class="btn listing-form-cancel cimerko-light-pill">Cancel</a>
                <button type="submit"
                        class="btn listing-form-submit cimerko-primary-button">
                    Submit for approval
                    <svg viewBox="0 0 24 24" aria-hidden="true">
                        <path d="m9 18 6-6-6-6"/>
                    </svg>
                </button>
            </div>
        </div>

        <aside class="listing-form-aside detail-card">
            <div class="listing-form-aside-icon">
                <svg viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M12 3 4 7v5c0 4.8 3.3 8 8 9 4.7-1 8-4.2 8-9V7l-8-4Z"/>
                    <path d="m9 12 2 2 4-4"/>
                </svg>
            </div>
            <h2>Before you submit</h2>
            <p>An admin reviews each listing before it appears publicly.</p>
            <ul>
                <li>
                    <span>1</span>
                    <div>
                        <strong>Use a clear title</strong>
                            <small>Mention the room or place, not just “available”.</small>
                    </div>
                </li>
                <li>
                    <span>2</span>
                    <div>
                        <strong>Describe the household</strong>
                        <small>Daily routines help the right roommate decide.</small>
                    </div>
                </li>
                <li>
                    <span>3</span>
                    <div>
                        <strong>Protect private details</strong>
                        <small>You can share an approximate location first.</small>
                    </div>
                </li>
            </ul>
        </aside>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial"/>
    <script>
        (() => {
            const input = document.getElementById("listingImages");
            const label = document.getElementById("listingImagesLabel");
            const selection = document.getElementById("listingImageSelection");
            const count = document.getElementById("listingImageCount");
            const previews = document.getElementById("listingImagePreviews");
            let previewUrls = [];

            input.addEventListener("change", () => {
                previewUrls.forEach(url => URL.revokeObjectURL(url));
                previewUrls = [];
                previews.replaceChildren();

                const files = Array.from(input.files);
                selection.hidden = files.length === 0;
                label.textContent = files.length === 0
                    ? "Choose listing images"
                    : "Change selected images";
                count.textContent = files.length === 1
                    ? "1 image selected"
                    : `${files.length} images selected`;

                files.slice(0, 5).forEach(file => {
                    const previewUrl = URL.createObjectURL(file);
                    const image = document.createElement("img");
                    previewUrls.push(previewUrl);
                    image.src = previewUrl;
                    image.alt = file.name;
                    previews.appendChild(image);
                });
            });
        })();
    </script>
}
