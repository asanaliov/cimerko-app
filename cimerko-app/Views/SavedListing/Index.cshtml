@using cimerko_app.Models.Enums
@model IEnumerable<SavedListing>

@{
    ViewData["Title"] = "Saved listings";
    var savedListings = Model.ToList();
}

<div class="saved-listings-page">
    <header class="saved-listings-header">
        <div>
            <span class="listing-eyebrow">Your shortlist</span>
            <h1>Saved listings</h1>
            <p>Keep track of places you are interested in.</p>
        </div>
        @if (savedListings.Count > 0) {
            <span class="saved-listings-count">
                @savedListings.Count @(savedListings.Count == 1 ? "listing" : "listings")
            </span>
        }
    </header>

    @if (savedListings.Count == 0) {
        <div class="listing-empty-state saved-listings-empty">
            <div class="listing-empty-icon">
                <svg viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M6 4.5h12v16l-6-3.8-6 3.8z"/>
                    <path d="M9 9h6"/>
                </svg>
            </div>
            <h2>You have not saved any listings yet.</h2>
            <p>Browse available places and save the ones you want to revisit.</p>
            <a asp-controller="Listing" asp-action="Index" class="btn listing-empty-action">
                Browse listings
            </a>
        </div>
    }
    else {
        <div class="listing-grid saved-listings-grid">
            @foreach (var savedListing in savedListings) {
                if (savedListing.Listing is not { } listing) {
                    continue;
                }

                var typeLabel = listing.Type.GetDisplayName();
                var location = string.IsNullOrWhiteSpace(listing.Address)
                    ? listing.City
                    : $"{listing.City} · {listing.Address}";
                var primaryImage = listing.Images
                    .OrderByDescending(image => image.IsPrimary)
                    .ThenBy(image => image.CreatedAt)
                    .FirstOrDefault();

                <article class="listing-card saved-listing-card">
                    <div class="listing-card-accent">
                        <span class="listing-type-badge @(listing.Type == ListingType.PlaceForRent ? "is-place" : "is-roommate")">
                            @typeLabel
                        </span>
                        <span class="listing-posted-date">Saved @savedListing.SavedAt.ToString("dd MMM")</span>
                        <svg class="listing-card-placeholder" viewBox="0 0 120 90" aria-hidden="true">
                            <path d="M18 70V35l30-20 30 20v35"/>
                            <path d="M33 70V46h30v24M83 70V28l19 12v30M8 70h104"/>
                            <path d="M43 54h10M91 46h5M91 55h5"/>
                        </svg>
                        @if (primaryImage != null) {
                            <img src="@primaryImage.ImageUrl"
                                 alt="@listing.Title"
                                 loading="lazy"
                                 onerror="this.hidden=true"/>
                        }
                    </div>

                    <div class="listing-card-body">
                        <div class="listing-card-price">
                            <strong>@listing.MonthlyRent.ToString("0") €</strong>
                            <span>/ month</span>
                        </div>

                        <h3>
                            <a asp-controller="Listing" asp-action="Details" asp-route-id="@listing.Id">
                                @listing.Title
                            </a>
                        </h3>

                        <p class="listing-card-location" title="@location">
                            <svg viewBox="0 0 24 24" aria-hidden="true">
                                <path d="M20 10c0 5-8 11-8 11S4 15 4 10a8 8 0 1 1 16 0Z"/>
                                <circle cx="12" cy="10" r="2.5"/>
                            </svg>
                            @location
                        </p>

                        <div class="listing-card-facts">
                            <span>
                                <svg viewBox="0 0 24 24" aria-hidden="true">
                                    <path d="M4 11h16v8H4zM7 11V7h4a3 3 0 0 1 3 3v1M4 16h16"/>
                                </svg>
                                @listing.RoomCount @(listing.RoomCount == 1 ? "room" : "rooms")
                            </span>
                            @if (listing.Type == ListingType.LookingForRoommate &&
                                 listing.RoommatesNeeded.HasValue) {
                                <span>
                                    <svg viewBox="0 0 24 24" aria-hidden="true">
                                        <circle cx="9" cy="8" r="3"/>
                                        <circle cx="17" cy="10" r="2"/>
                                        <path d="M3 19c.4-4 2.4-6 6-6s5.6 2 6 6M15 15c3 0 4.7 1.3 5 4"/>
                                    </svg>
                                    @listing.RoommatesNeeded needed
                                </span>
                            }
                        </div>
                    </div>

                    <div class="listing-card-footer saved-listing-card-footer">
                        <a asp-controller="Listing"
                           asp-action="Details"
                           asp-route-id="@listing.Id"
                           class="saved-listing-details">
                            View details
                            <svg viewBox="0 0 24 24" aria-hidden="true">
                                <path d="m9 18 6-6-6-6"/>
                            </svg>
                        </a>

                        <form asp-action="Remove" method="post">
                            <input type="hidden" name="listingId" value="@listing.Id"/>
                            <button type="submit" class="saved-listing-remove">
                                <svg viewBox="0 0 24 24" aria-hidden="true">
                                    <path d="M12 20.5 4.8 13.7A5.2 5.2 0 0 1 12 6.2a5.2 5.2 0 0 1 7.2 7.5Z"/>
                                    <path d="M8 12h8"/>
                                </svg>
                                Unsave
                            </button>
                        </form>
                    </div>
                </article>
            }
        </div>
    }
</div>
